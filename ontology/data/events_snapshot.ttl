<https://planorama.example.org/resource/event/17u8v0G61XSaP_f>	rdf:type	ns2:Event ;
	ns4:sourceId	"17u8v0G61XSaP_f" ;
	ns2:description	"Get set for the men's world cup of tennis as the Davis Cup returns to London at the Copper Box Arena this September. Watch as the Lexus Great Britain team take on Ecuador in Qualifiers for a place in the Davis Cup Finals. Be part of the action and cheer on the British side as they aim to bring home the title for the first time since 2015. This best-of-five match tie will take place over two days from 19-20 September. There will be two singles matches on Saturday 19, followed by up to three matches on Sunday 20, including one doubles and two singles matches." ;
	ns2:image	<https://s1.ticketm.net/dam/a/5cb/c933a744-9403-4b9e-ac8f-9bcd43ee55cb_RETINA_LANDSCAPE_16_9.jpg> ;
	ns2:startDate	"2026-09-19"^^xsd:date ;
	ns2:url	<https://www.ticketmaster.co.uk/gb-vs-ecuador-davis-cup-2nd-london-19-09-2026/event/350064AFB3265654> ;
	ns4:hasCategory	ns6:sports-tennis-tennis ;
	ns2:name	"GB vs Ecuador: Davis Cup - 2nd Round Qualifiers" ;
	ns2:location	ns7:KovZ9177tC7 ;
	ns2:performer	"Davis Cup" ;
	ns2:organizer	"LONDON LEGACY DEVELOPMENT CORPORATION" .
