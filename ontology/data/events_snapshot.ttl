ns7:KovZ9177yOV	rdf:type	ns2:Place ;
	ns4:accessibilityNote	"Wembley Arena operates a dedicated disabled customer booking line. For all enquiries or to book tickets, please call 020 8782 5629 The accessible booking line is open Monday \u00C3\u00A2\u00C2\u0080\u00C2\u0093 Friday (9am - 7pm) Saturday & Sunday (10am-6pm)." ;
	ns4:hasAccessibleSeating	"true"^^xsd:boolean ;
	ns4:sourceId	"KovZ9177yOV" ;
	ns2:address	ns49:address ;
