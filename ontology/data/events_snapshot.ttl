ns3:G5dIZ_k2QVuiV	rdf:type	ns2:Event ;
	ns4:sourceId	"G5dIZ_k2QVuiV" ;
	ns2:description	"\"The Looking Out Foundation amplifies the impact of music by empowering those without a voice. From neighborhood to nation, we fund causes and organizations that often go unnoticed to support social justice and humanitarian causes across the US and globally. Founded in 2008 by multiple Grammy winning artist Brandi Carlile, we band together with fans, non-profits and female LGBTQ+ owned businesses to translate voices of song to voices of action. We are nimble to the ever-changing needs of the human race and adapt to support the diverse demographic we serve. Every campaign we launch is backed by our passionate donors and fans, and $2 from every concert ticket sold goes directly toward our efforts.\"" ;
	ns2:image	ns246:c4a80336-03fe-439f-ae7d-7e8a91c6f3f6_SOURCE ;
	ns2:startDate	"2026-09-07T00:00:00Z"^^xsd:dateTime ;
